# =============================================================================
# agent-middleware — environment configuration
# =============================================================================
# Copy to `.env` and fill in real values. `.env` is gitignored.

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
PORT=3000
# Cwd for the restart helper to relaunch from. Should match this repo's root.
MIDDLEWARE_DIR=/mnt/c/dev/agent-middleware

# -----------------------------------------------------------------------------
# Auth tokens (generate with `openssl rand -hex 32`)
# -----------------------------------------------------------------------------
MIDDLEWARE_TOKEN=
CANON_COMMIT_TOKEN=
# Comma-separated CIDR or IP allowlist for canon-commit endpoints (default 127.0.0.1).
# On Spark #2 deployment this should also include the LAN range NemoClaw connects from.
CANON_COMMIT_ALLOWED_IPS=127.0.0.1

# -----------------------------------------------------------------------------
# Discord bots
# -----------------------------------------------------------------------------
DISCORD_BOT_TOKEN=
TARGET_CHANNEL_ID=
NEMOCLAW_BOT_ID=

QWEN_BOT_TOKEN=
QWEN_CHANNEL_ID=
QWEN_ROLE_ID=
QWEN_SHOW_THINKING=false

# -----------------------------------------------------------------------------
# Claude CLI
# -----------------------------------------------------------------------------
# Working directory for spawned `claude` processes — should be a clone of dcc
# containing CLAUDE.md and .claude/skills/. On Spark #2: /home/bender/dcc (sparse).
CLAUDE_CWD=/mnt/c/dev/dcc
# Additional repos Claude can read/write via --add-dir. Colon-separated.
CLAUDE_ADD_DIRS=/mnt/c/dev/agent-middleware:/mnt/c/dev/dcc-canon-rag
CLAUDE_MODEL=claude-opus-4-7

# -----------------------------------------------------------------------------
# Canon commit / worktree
# -----------------------------------------------------------------------------
CANON_REPO_PATH=/mnt/c/dev/dcc
# Use a durable path on a server (not /tmp).
CANON_STATE_DIR=/var/lib/agent-middleware/canon
CANON_WORKTREE_DIR=/var/lib/agent-middleware/canon-worktree
CANON_TRUTH_ROOT=

# -----------------------------------------------------------------------------
# Qwen client (vLLM on Spark #1)
# -----------------------------------------------------------------------------
QWEN_VLLM_URL=http://192.168.1.20:8090/v1
QWEN_API_KEY=EMPTY
QWEN_MODEL_NAME=
QWEN_REQUEST_TIMEOUT_MS=

# -----------------------------------------------------------------------------
# Qwen harness state
# -----------------------------------------------------------------------------
QWEN_SESSIONS_DIR=/var/lib/agent-middleware/qwen-sessions
QWEN_PERSONA_DIR=/var/lib/agent-middleware/qwen-persona
QWEN_PERSONA_TTL_MS=60000
QWEN_WALL_CLOCK_MS=300000
QWEN_SESSION_IDLE_MS=1800000

# -----------------------------------------------------------------------------
# Qwen vector memory (sqlite-vec)
# -----------------------------------------------------------------------------
QWEN_MEMORY_DB=/var/lib/agent-middleware/qwen-memory.db
# Embedding service. After migration: localhost when colocated with dcc-canon-rag on Spark #2.
RAG_EMBED_URL=http://localhost:3001/embed

# -----------------------------------------------------------------------------
# Canon search (dcc-canon-rag service)
# -----------------------------------------------------------------------------
CANON_SEARCH_URL=http://localhost:3001/search

# -----------------------------------------------------------------------------
# MemPalace (shared memory on Spark #2)
# -----------------------------------------------------------------------------
MEMPALACE_ENABLED=true
MEMPALACE_URL=http://192.168.1.8:8100
MEMPALACE_TOKEN=
